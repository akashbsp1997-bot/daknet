# TEMPLATE — placeholder values only, and deliberately NOT applied by the
# CI workflow (see .github/workflows/deploy-k8s.yml). If CI re-applied this
# file on every push, it would overwrite your real secret values back to
# "REPLACE_ME" every single deploy. Apply this ONCE, by hand, after filling
# in real values — or skip this file entirely and run the imperative
# version instead, which never puts real secrets in a file at all:
#
#   kubectl create secret generic postman-api-secrets \
#     --from-literal=DATABASE_URL='postgres://...' \
#     --from-literal=JWT_SECRET='...' \
#     --from-literal=R2_ACCOUNT_ID='...' \
#     --from-literal=R2_ACCESS_KEY_ID='...' \
#     --from-literal=R2_SECRET_ACCESS_KEY='...' \
#     --from-literal=R2_BUCKET_NAME='...'
#
# This file is gitignored already — see .gitignore — so filling in real
# values here and applying it locally won't accidentally get committed.
apiVersion: v1
kind: Secret
metadata:
  name: postman-api-secrets
type: Opaque
stringData:
  DATABASE_URL: "postgres://REPLACE_ME"
  JWT_SECRET: "REPLACE_ME"
  R2_ACCOUNT_ID: "REPLACE_ME"
  R2_ACCESS_KEY_ID: "REPLACE_ME"
  R2_SECRET_ACCESS_KEY: "REPLACE_ME"
  R2_BUCKET_NAME: "REPLACE_ME"

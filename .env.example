# Canonical source of truth for every secret/config value this project needs,
# across Render (postman-api), GitHub Actions (CI secrets/variables), and the
# Supabase-backed database/storage.
#
# Copy this file to `.env` (already gitignored) and fill in real values.
# Then run: node scripts/sync-secrets.mjs
# That pushes each value to the right place — see the "targets" note above
# each variable — so you only ever maintain values in one file.

# --- Database (Supabase Postgres) --------------------------------------
# targets: render, github-secret (github: used by .github/workflows/db-push.yml)
DATABASE_URL=

# --- Auth ----------------------------------------------------------------
# targets: render
JWT_SECRET=

# Bootstrap super-admin account. Only ever created once, on postman-api's
# first successful startup with these set — changing them later does NOT
# update or recreate the account. See apps/postman-api/src/routes/auth.ts.
# targets: render
SUPER_ADMIN_USERNAME=
SUPER_ADMIN_PASSWORD=

# --- Supabase Storage (S3-compatible, for visit/address photos) ---------
# targets: render
SUPABASE_S3_ENDPOINT=
SUPABASE_S3_REGION=
SUPABASE_S3_ACCESS_KEY_ID=
SUPABASE_S3_SECRET_ACCESS_KEY=
SUPABASE_S3_BUCKET_NAME=

# --- Frontend build-time config ------------------------------------------
# targets: github-variable (baked into the postman/postbook builds by
# .github/workflows/deploy-pages.yml — not secret, it's a public API URL)
VITE_API_URL=https://daknet.onrender.com/

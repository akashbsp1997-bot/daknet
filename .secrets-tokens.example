# Credentials the sync script itself needs to talk to GitHub and Render.
# These are NOT app secrets — they're your personal admin tokens, used only
# locally to push .env's contents out to both platforms.
#
# Copy this file to `.secrets-tokens` (already gitignored) and fill in real
# values. Never commit the filled-in file.

# GitHub personal access token with 'repo' scope (classic) or, for a fine-
# grained token, "Secrets" + "Variables" read/write on this repository.
# Create one at https://github.com/settings/tokens
GH_TOKEN=

# Repo the secrets/variables get written to. Leave blank to auto-detect
# from `git remote get-url origin` in this checkout.
GITHUB_OWNER=akashbsp1997-bot
GITHUB_REPO=daknet

# Render API key. Create one at https://dashboard.render.com/u/settings#api-keys
RENDER_API_KEY=

# The postman-api service's Render ID (starts with "srv-"). Leave blank to
# auto-detect by name via the Render API (assumes the service is named
# "postman-api" — check your Render dashboard if that's not the case).
RENDER_SERVICE_ID=
